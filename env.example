# ─────────────────────────────────────────────────────────────────────────────
# REFERENCE ONLY. Do not edit this for your install.
# `./install.sh` generates a real .env from this file + GPU detection, and fills
# the secrets at the bottom once. .env is gitignored; this file is committed so
# every key is documented. Quote any value containing spaces.
# ─────────────────────────────────────────────────────────────────────────────

# Compose project name (container/volume prefix)
COMPOSE_PROJECT_NAME=ai-stack

# Bind-mount root. Kept OUTSIDE the git clone on purpose so `git clean` can never
# delete your models or data. Must be on a disk with room for models (tens-to-
# hundreds of GB).
DATA_ROOT=/opt/local-ai-stack/data

# ── Exposure (only these two services publish host ports) ──
WEBUI_PORT=8080
OPENCLAW_PORT=18789

# ── GPU ── set by the installer (nvidia | amd | cpu). Override here to force.
GPU_VENDOR=
# NVIDIA: how many GPUs Ollama may use ("all" or an integer) and which devices.
OLLAMA_GPU_COUNT=all
NVIDIA_VISIBLE_DEVICES=all
# AMD only, card-specific gfx override (uncomment if your card needs it):
# HSA_OVERRIDE_GFX_VERSION=11.0.0

# ── Images (default :latest; pin a tag here if you want determinism) ──
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_IMAGE_AMD=ollama/ollama:rocm
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
SEARXNG_IMAGE=searxng/searxng:latest
WATCHTOWER_IMAGE=nickfedor/watchtower:latest

# Default local model id. Must be pulled in Open WebUI first. Used as OpenClaw's
# allowlisted/primary model. qwen2.5:1.5b is a deliberately small, CPU-safe
# default (~1 GB). See README "Choosing a model" to size up for GPU/RAM.
DEFAULT_MODEL=qwen2.5:1.5b

# Watchtower auto-update schedule (6-field cron). OpenClaw is excluded via label
# and updated only via `./install.sh update`.
WATCHTOWER_SCHEDULE="0 0 4 * * *"

# ─────────────────────────────────────────────────────────────────────────────
# Secrets — generated once by the installer if empty. DO NOT COMMIT a filled .env.
# ─────────────────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=
WEBUI_SECRET_KEY=
SEARXNG_SECRET=
OPENCLAW_GATEWAY_TOKEN=
